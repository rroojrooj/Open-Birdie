{
  "name": "open-birdie",
  "version": "0.9.1",
  "description": "Open-data golf simulator: plays real OpenStreetMap courses with any GSPro Open Connect launch monitor (Uneekor VIEW/GSPconnect, etc.)",
  "main": "main.js",
  "author": "Rooj Rin",
  "type": "commonjs",
  "scripts": {
    "test": "node --test \"test/*.test.js\" \"test/*.test.mjs\"",
    "start": "electron .",
    "start:server": "node server.js",
    "calibrate": "node tools/calibrate.js",
    "shot": "node tools/test-shot.js",
    "watch": "node tools/uneekor-watch.js --speed-scale 2.23694",
    "make-icon": "node tools/make-icon.js",
    "discover:hd-hole": "node tools/hd-course/cli.mjs discover",
    "build:hd-hole": "node tools/hd-course/cli.mjs build",
    "validate:hd-bundle": "node tools/validate-hd-bundle.js",
    "smoke:hd-providers": "node tools/smoke-hd-providers.mjs",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "build": {
    "appId": "io.github.rroojrooj.open-birdie",
    "productName": "Open-Birdie",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "server.js",
      "lib/**/*",
      "public/**/*",
      "tools/uneekor-watch.js",
      "!**/*.md",
      "!data",
      "!docs",
      "!test",
      "!.claude"
    ],
    "asar": true,
    "asarUnpack": [
      "tools/uneekor-watch.js"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Open-Birdie",
      "runAfterFinish": true,
      "artifactName": "Open-Birdie-Setup-${version}.${ext}"
    }
  },
  "dependencies": {
    "pngjs": "^7.0.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "ajv": "^8.20.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "geotiff": "^3.0.5",
    "proj4": "^2.20.9",
    "sharp": "^0.35.2"
  }
}
