{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://open-birdie/hd/build-manifest.schema.json",
  "title": "HD hole build manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion", "course", "hole", "padding",
    "terrain", "imagery", "providers", "limits", "normalization", "discovered"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "course": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "cacheVersion", "fingerprint"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "cacheVersion": { "type": "integer", "minimum": 1 },
        "fingerprint": {
          "type": "string",
          "anyOf": [{ "pattern": "^[a-f0-9]{64}$" }, { "const": "pending" }]
        }
      }
    },
    "hole": { "type": "integer", "minimum": 1, "maximum": 18 },
    "padding": { "type": "number", "minimum": 0, "maximum": 1000 },
    "terrain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["targetSpacingM", "crs"],
      "properties": {
        "targetSpacingM": { "type": "number", "minimum": 0.1, "maximum": 50 },
        "nativeSpacingM": { "type": "number", "minimum": 0.1, "maximum": 50 },
        "maxPx": { "type": "integer", "minimum": 8, "maximum": 20000 },
        "crs": { "type": "string", "enum": ["EPSG:3857", "EPSG:4326"] }
      }
    },
    "imagery": {
      "type": "object",
      "additionalProperties": false,
      "required": ["collection", "date", "gsdM", "itemIds"],
      "properties": {
        "collection": { "type": "string", "minLength": 1 },
        "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "gsdM": { "type": "number", "minimum": 0.05, "maximum": 5 },
        "itemIds": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "providers": {
      "type": "object",
      "additionalProperties": false,
      "required": ["elevation", "imagery"],
      "properties": {
        "elevation": { "type": "string", "pattern": "^https://" },
        "imagery": { "type": "string", "pattern": "^https://" }
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxPixels", "maxDownloadBytes", "maxBundleBytes"],
      "properties": {
        "maxPixels": { "type": "integer", "minimum": 1, "maximum": 2000000000 },
        "maxDownloadBytes": { "type": "integer", "minimum": 1 },
        "maxBundleBytes": { "type": "integer", "minimum": 1 }
      }
    },
    "normalization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format"],
      "properties": {
        "format": { "type": "string", "enum": ["webp", "jpeg"] },
        "quality": { "type": "integer", "minimum": 1, "maximum": 100 }
      }
    },
    "discovered": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["state"],
          "properties": { "state": { "const": "pending" } }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["state", "bounds", "assets"],
          "properties": {
            "state": { "const": "resolved" },
            "bounds": {
              "type": "object",
              "additionalProperties": false,
              "required": ["minX", "minY", "maxX", "maxY"],
              "properties": {
                "minX": { "type": "number" },
                "minY": { "type": "number" },
                "maxX": { "type": "number" },
                "maxY": { "type": "number" }
              }
            },
            "assets": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["url", "contentLength", "etag"],
                "properties": {
                  "url": { "type": "string", "pattern": "^https://" },
                  "contentLength": { "type": "integer", "minimum": 1 },
                  "etag": { "type": "string", "minLength": 1 }
                }
              }
            }
          }
        }
      ]
    }
  }
}
