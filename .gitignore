# dependencies
node_modules/

# electron-builder output (installer + unpacked app; regenerates via npm run dist)
dist/

# downloaded course + terrain cache (regenerates on demand from open data)
data/courses/*.json

# HD compiler build workspace + generated hole bundles
# (regenerate from open 3DEP/NAIP data; too large for normal git history)
data/hd-build-cache/
data/hd-courses/

# throwaway render-capture sink + screenshots (dev verification only)
.shots/
# static HUD preview harness (WebGL-free, for screenshotting the HUD)
public/_hudmock.html
public/_bg.jpg

# logs / OS cruft
npm-debug.log*
*.log
.DS_Store
Thumbs.db
.gstack/
